	column StartOfMonth = DATE(YEAR('Calendrier'[Date]), MONTH('Calendrier'[Date]), 1)
		formatString: mmmm yyyy
		lineageTag: 153d5511-6284-49c1-9819-97d2b89ebe59
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 76f07023-b28a-45f5-8c8a-5fab62a037cc
			defaultHierarchy: LocalDateTable_0a7a180f-84c3-4bf4-8aee-7e4452366d6e.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	partition Calendrier = calculated
		mode: import
		source = ```
				
				
				ADDCOLUMNS(
				    CALENDAR(
				        DATE(2023,1,1),
				        DATE(2025,12,31)
				    ),
				    "Annee", FORMAT([Date],"YYYY"),
				    "Trimestre" , "T"&FORMAT([Date],"Q"),
				    "Annee mois", FORMAT([Date],"YYYYMM"),
				    "Nom du mois", FORMAT([Date],"MMM") ,
				    "Numero du mois", MONTH([Date]),
				    "Semaine", YEAR([Date])&"S"&WEEKNUM([Date],21),
				    "Numero de la semaine", WEEKNUM([Date],21),
				    "Nom du jour", FORMAT([Date],"DDDD"),
				    "Numero du jour" , WEEKDAY([Date],2),
				    "Jour ouvre" , IF(WEEKDAY([Date],2)>6,"Week-end")
				)
				
				```

	annotation PBI_Id = 9793397900bc4609a1a0fa452fb8dadb

