	measure 'Action à mener' =
			
			IF(
			    MAX( Factures[est_retard_23032026] ) <> 1,
			    BLANK(),
			    SWITCH(
			        TRUE(),
			        MAX( Factures[JoursRetard] ) < 30, "Rappel amiable",
			        MAX( Factures[JoursRetard] ) < 60, "Relance formelle",
			        MAX( Factures[JoursRetard] ) < 90, "Mise en demeure",
			        "Contentieux"
			    )
			)
		displayFolder: Relances & Retards
		lineageTag: ede49c5d-4906-4b65-a4d8-50572fce24c4

	measure 'Niveau Urgence' =
			
			SWITCH(
			    TRUE(),
			    MAX( Factures[JoursRetard] ) < 30, 1,
			    MAX( Factures[JoursRetard] ) < 60, 2,
			    MAX( Factures[JoursRetard] ) < 90, 3,
			    4
			)
		formatString: 0
		displayFolder: Relances & Retards
		lineageTag: b97eb127-08f3-4de2-98eb-569528c8e428

	measure 'Année sélectionnée' =
			
			SELECTEDVALUE('Calendrier'[Annee])
		displayFolder: Filtres
		lineageTag: db0c0aff-7c12-4f1d-a382-e8010b42d650

	measure 'Variation CA' =
			
			VAR _anneeTxt = [Année sélectionnée]
			VAR _anneeNum = VALUE(_anneeTxt)
			VAR _n =
			    CALCULATE(
			        [CA facture ht],
			        REMOVEFILTERS('Calendrier'[Annee]),
			        'Calendrier'[Annee] = FORMAT(_anneeNum, "0")
			    )
			VAR _n1 =
			    CALCULATE(
			        [CA facture ht],
			        REMOVEFILTERS('Calendrier'[Annee]),
			        'Calendrier'[Annee] = FORMAT(_anneeNum - 1, "0")
			    )
			RETURN
			IF(
			    ISBLANK(_anneeTxt) || ISBLANK(_n1) || _n1 = 0,
			    BLANK(),
			    DIVIDE(_n - _n1, _n1)
			)
		formatString: 0
		displayFolder: Chiffre d'affaire
		lineageTag: 4b4a195b-3630-43eb-9498-eba8c4f3a00f

	measure 'Variation Marge Nette' =
			
			VAR _anneeTxt = SELECTEDVALUE('Calendrier'[Annee])
			VAR _anneeNum = VALUE(_anneeTxt)
			VAR _n =
			    CALCULATE(
			        [Marge Nette %],
			        REMOVEFILTERS('Calendrier'),
			        'Calendrier'[Annee] = FORMAT(_anneeNum, "0")
			    )
			VAR _n1 =
			    CALCULATE(
			        [Marge Nette %],
			        REMOVEFILTERS('Calendrier'),
			        'Calendrier'[Annee] = FORMAT(_anneeNum - 1, "0")
			    )
			RETURN
			IF(
			    ISBLANK(_anneeTxt) || ISBLANK(_n) || ISBLANK(_n1),
			    BLANK(),
			    _n - _n1
			)
		displayFolder: Rentabilité chantier
		lineageTag: a45d964e-5f08-43a5-b603-6ef02b6ab4a3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Titre CA' =
			
			VAR _var = [Variation CA]
			VAR _anneeTxt = [Année sélectionnée]
			VAR _anneeNum = VALUE(_anneeTxt)
			VAR _signe = IF(_var >= 0, "▲ +", "▼ ")
			VAR _pct = FORMAT(ABS(_var), "0,0%")
			RETURN
			IF(
			    ISBLANK(_var),
			    "Pas de comparaison disponible",
			    _signe & _pct & " vs " & FORMAT(_anneeNum - 1, "0")
			)
		displayFolder: Chiffre d'affaire
		lineageTag: 63e0f12b-5d93-4ed4-b32e-bd155ebd0940

	measure 'Titre EBE' =
			
			VAR _var = [Variation EBE]
			VAR _annee = [Année sélectionnée]
			VAR _signe = IF(_var >= 0, "▲ +", "▼ ")
			VAR _pct = FORMAT(ABS(_var), "#,0%")
			RETURN
			IF(
			    ISBLANK(_var),
			    "Pas de comparaison disponible",
			    _signe & _pct & " vs " & (_annee - 1)
			)
		displayFolder: EBE annuel
		lineageTag: 8350483e-ab5c-48a1-9f2a-192fb5f8eb70

	measure 'Variation EBE' =
			
			VAR _anneeTxt = [Année sélectionnée]
			VAR _anneeNum = VALUE(_anneeTxt)
			VAR _n =
			    CALCULATE(
			        [EBE],
			        REMOVEFILTERS('Calendrier'[Annee]),
			        'Calendrier'[Annee] = FORMAT(_anneeNum, "0")
			    )
			VAR _n1 =
			    CALCULATE(
			        [EBE],
			        REMOVEFILTERS('Calendrier'[Annee]),
			        'Calendrier'[Annee] = FORMAT(_anneeNum - 1, "0")
			    )
			RETURN
			IF(
			    ISBLANK(_anneeTxt) || ISBLANK(_n1) || _n1 = 0,
			    BLANK(),
			    DIVIDE(_n - _n1, _n1)
			)
		displayFolder: EBE annuel
		lineageTag: 63193936-36d6-4d87-921c-fc8fe3ab813d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Titre Marge Nette' =
			
			VAR _var = [Variation Marge Nette]
			VAR _anneeTxt = SELECTEDVALUE('Calendrier'[Annee])
			VAR _anneeNum = VALUE(_anneeTxt)
			VAR _signe = IF(_var >= 0, "▲ +", "▼ ")
			VAR _pts = ROUND(ABS(_var) * 100, 1)
			VAR _ptsTxt =
			    IF(
			        ABS(_pts - ROUND(_pts, 0)) < 0.000001,
			        FORMAT(_pts, "0"),
			        FORMAT(_pts, "0.0")
			    )
			RETURN
			IF(
			    ISBLANK(_var),
			    "Pas de comparaison disponible",
			    _signe & _ptsTxt & " pp vs " & FORMAT(_anneeNum - 1, "0")
			)
