		lineageTag: c97f53b2-aae5-4d5b-a225-7e67407c73d3

	measure 'CA Moyen / Chantier' = DIVIDE( [CA facture ht], [Nb Chantiers] )
		displayFolder: Chiffre d'affaire
		lineageTag: 31a6e4cd-cdb9-4c10-9964-2786f117e664

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Couts Personnel' =
			
			CALCULATE(
			  SUM( Couts[montant_ht] ),
			  Couts[type_cout] = "Personnel"
			)
		formatString: 0
		displayFolder: Couts opérationnels
		lineageTag: 868edac6-583e-452a-a938-c60b10a32c9f

	measure 'Couts Achats' =
			
			CALCULATE(
			  SUM( Couts[montant_ht] ),
			  Couts[type_cout] = "Achats"
			)
		formatString: 0
		displayFolder: Couts opérationnels
		lineageTag: 3b805dee-5656-4fd3-86a3-df6793373bee

	measure 'Couts Charges Ext.' =
			
			CALCULATE(
			  SUM( Couts[montant_ht] ),
			  Couts[type_cout] = "Charges externes"
			)
		formatString: 0
		displayFolder: Couts opérationnels
		lineageTag: a5b03123-431a-41fc-9e51-8cd02c33c6cb

	measure '% Personnel / CA' =
			
			DIVIDE( [Couts Personnel], [CA facture ht] )
		displayFolder: Couts opérationnels
		lineageTag: 39c70538-ea06-4066-8ea6-23914b7b4b64

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Resultat Net Chantier' =
			
