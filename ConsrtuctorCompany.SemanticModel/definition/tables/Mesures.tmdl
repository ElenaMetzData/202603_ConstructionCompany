	measure 'Action à mener' =
			
			IF(
			    MAX( Factures[est_retard_23032026] ) <> 1,
			    BLANK(),
			    SWITCH(
			        TRUE(),
			        MAX( Factures[JoursRetard] ) < 30, "Rappel amiable",
			        MAX( Factures[JoursRetard] ) < 60, "Relance formelle",
			        MAX( Factures[JoursRetard] ) < 90, "Mise en demeure",
			        "Contentieux"
			    )
			)
		displayFolder: Relances & Retards
		lineageTag: ede49c5d-4906-4b65-a4d8-50572fce24c4

	measure 'Niveau Urgence' =
			
			SWITCH(
			    TRUE(),
			    MAX( Factures[JoursRetard] ) < 30, 1,
			    MAX( Factures[JoursRetard] ) < 60, 2,
			    MAX( Factures[JoursRetard] ) < 90, 3,
			    4
			)
		formatString: 0
		displayFolder: Relances & Retards
		lineageTag: b97eb127-08f3-4de2-98eb-569528c8e428

	column Value
		isHidden
		formatString: 0
		lineageTag: 0967da8d-e855-4966-b9df-c4abd29e8b02
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Value]

		annotation SummarizationSetBy = Automatic

	partition Mesures = calculated
		mode: import
		source = Row("Value", BLANK())

	annotation PBI_Id = b30450085a2749dfa553103aac4e23f9

	annotation 436ba87b-9c83-4389-a31b-ebd06a36be98 = {"Expression":""}

