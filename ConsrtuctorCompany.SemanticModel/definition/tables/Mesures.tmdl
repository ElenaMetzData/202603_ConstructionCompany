	measure ShowFilter = ```
			
			VAR MaxFilters = 3
			RETURN
			IF ( 
			    ISFILTERED ( Calendrier[Annee] ), 
			    VAR ___f = FILTERS ( Calendrier[Annee] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, Calendrier[Annee] )
			    VAR ___d = CONCATENATEX ( ___t, Calendrier[Annee], ", " )
			    VAR ___x = "Année =" & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			 & IF ( 
			    ISFILTERED ( Calendrier[StartOfMonth] ), 
			    VAR ___f = FILTERS ( Calendrier[StartOfMonth] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, Calendrier[StartOfMonth] )
			    VAR ___d = CONCATENATEX ( ___t, Calendrier[StartOfMonth], ", " )
			    VAR ___x = "Calendrier[StartOfMonth] = " & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			 
			 & IF ( 
			    ISFILTERED ( Chantiers[annee_debut] ), 
			    VAR ___f = FILTERS ( Chantiers[annee_debut] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, Chantiers[annee_debut] )
			    VAR ___d = CONCATENATEX ( ___t, Chantiers[annee_debut], ", " )
			    VAR ___x = "Chantiers[annee_debut] = " & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			 & IF ( 
			    ISFILTERED ( Chantiers[ca_facture_ht] ), 
			    VAR ___f = FILTERS ( Chantiers[ca_facture_ht] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, Chantiers[ca_facture_ht] )
			    VAR ___d = CONCATENATEX ( ___t, Chantiers[ca_facture_ht], ", " )
			    VAR ___x = "Chantiers[ca_facture_ht] = " & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			 & IF ( 
			    ISFILTERED ( Chantiers[ca_prevu_ht] ), 
			    VAR ___f = FILTERS ( Chantiers[ca_prevu_ht] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, Chantiers[ca_prevu_ht] )
			    VAR ___d = CONCATENATEX ( ___t, Chantiers[ca_prevu_ht], ", " )
			    VAR ___x = "Chantiers[ca_prevu_ht] = " & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			 & IF ( 
			    ISFILTERED ( Chantiers[chantier_id] ), 
			    VAR ___f = FILTERS ( Chantiers[chantier_id] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, Chantiers[chantier_id] )
			    VAR ___d = CONCATENATEX ( ___t, Chantiers[chantier_id], ", " )
			    VAR ___x = "Chantiers[chantier_id] = " & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			 & IF ( 
			    ISFILTERED ( Chantiers[client] ), 
			    VAR ___f = FILTERS ( Chantiers[client] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, Chantiers[client] )
			    VAR ___d = CONCATENATEX ( ___t, Chantiers[client], ", " )
			    VAR ___x = "Client = " & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			
			 & IF ( 
			    ISFILTERED ( Chantiers[date_debut] ), 
			    VAR ___f = FILTERS ( Chantiers[date_debut] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, Chantiers[date_debut] )
			    VAR ___d = CONCATENATEX ( ___t, Chantiers[date_debut], ", " )
			    VAR ___x = "Chantiers[date_debut] = " & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			 & IF ( 
			    ISFILTERED ( Chantiers[nom_chantier] ), 
			    VAR ___f = FILTERS ( Chantiers[nom_chantier] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, Chantiers[nom_chantier] )
			    VAR ___d = CONCATENATEX ( ___t, Chantiers[nom_chantier], ", " )
			    VAR ___x = "Chantiers[nom_chantier] = " & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			 & IF ( 
			    ISFILTERED ( Chantiers[type_client] ), 
			    VAR ___f = FILTERS ( Chantiers[type_client] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, Chantiers[type_client] )
			    VAR ___d = CONCATENATEX ( ___t, Chantiers[type_client], ", " )
			    VAR ___x = "Type de client = " & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			 & IF ( 
			    ISFILTERED ( Chantiers[type_travaux] ), 
			    VAR ___f = FILTERS ( Chantiers[type_travaux] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, Chantiers[type_travaux] )
			    VAR ___d = CONCATENATEX ( ___t, Chantiers[type_travaux], ", " )
			    VAR ___x = "Type de travaux = " & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			 & IF ( 
			    ISFILTERED ( Chantiers[ville] ), 
			    VAR ___f = FILTERS ( Chantiers[ville] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, Chantiers[ville] )
			    VAR ___d = CONCATENATEX ( ___t, Chantiers[ville], ", " )
			    VAR ___x = "Ville = " & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			---- MODEL MEASURES END ----
			
			
			```
		displayFolder: Filtres
		lineageTag: d9f49041-da2d-4287-9774-517ebde9dcd9

