	measure 'Encaissements Manqués Cumulés' =
			
			CALCULATE(
			    SUM( Factures[montant_retard_23032026] ),
			    FILTER(
			        ALL( 'Calendrier' ),
			        'Calendrier'[Date] <= MAX( 'Calendrier'[Date] )
			    )
			)
		formatString: 0
		displayFolder: Trésorerie & Encaissements
