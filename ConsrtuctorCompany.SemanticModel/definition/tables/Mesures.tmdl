		displayFolder: Rentabilité chantier
		lineageTag: d1fe23fd-a687-40ec-affb-3c87d859aae3

	measure 'Marge Nette %' =
			
			DIVIDE( [Resultat Net Chantier], [CA Facture HT] )
		displayFolder: Rentabilité chantier
		lineageTag: fd7bc459-5c23-414e-b3f8-4d2065914f5f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Depassement Budget' =
			
			[Total Couts HT] - [CA Prevu HT]
		displayFolder: Rentabilité chantier
		lineageTag: e351b870-ffc2-40c0-9f36-558be05f273c

	measure 'CA Annuel (EBE)' =
			
			CALCULATE(
			  SUM( Chantiers[ca_facture_ht] ),
			  REMOVEFILTERS( Chantiers[ville] ),
			  REMOVEFILTERS( Chantiers[type_client] ),
			  REMOVEFILTERS( Chantiers[type_travaux] )
			)
		formatString: 0
		displayFolder: EBE annuel
		lineageTag: 89363d4e-df2d-4870-b933-caf6e766fb3f

	measure EBE =
			
			[CA Annuel (EBE)] - [Couts Annuels (EBE)]
		displayFolder: EBE annuel
		lineageTag: 81196c5d-f07a-4f11-8c1c-596e162f37bd

	measure 'Couts Annuels (EBE)' =
			
			CALCULATE(
			  SUM( Couts[montant_ht] ),
			  REMOVEFILTERS( Chantiers[ville] ),
			  REMOVEFILTERS( Chantiers[type_client] ),
			  REMOVEFILTERS( Chantiers[type_travaux] )
			)
		formatString: 0
		displayFolder: EBE annuel
		lineageTag: 92bdee4c-085d-49c8-a75b-b524cdbdf408

	measure 'Taux EBE %' =
			
			DIVIDE( [EBE], [CA Annuel (EBE)] )
		displayFolder: EBE annuel
		lineageTag: 48c7764a-4436-42c6-b6f1-7768ddc1ff00

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'EBE Annee Prec.' =
			
			CALCULATE(
			  [EBE],
			  PREVIOUSYEAR( 'Calendrier'[Date] )
			)
		formatString: 0
		displayFolder: EBE annuel
		lineageTag: 858ee5d4-b23c-49da-980f-6cc79e140e24

	measure 'Variation EBE vs N-1' =
			
			DIVIDE(
			  [EBE] - [EBE Annee Prec.],
			  [EBE Annee Prec.]
			)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: EBE annuel
		lineageTag: 0787502f-1ddc-4c1f-abec-609cd5dccdda

	measure 'Montant Facture' =
			
			SUM( Factures[montant_ht] )
		formatString: 0
		displayFolder: Trésorerie & Encaissements
		lineageTag: 1b0a13f2-1970-4de6-8a92-75bbf13b9f13

	measure 'Montant Encaisse' =
			
			CALCULATE(
			  SUM( Factures[montant_ht] ),
			  Factures[date_paiement] <> BLANK()
			)
		formatString: 0
		displayFolder: Trésorerie & Encaissements
		lineageTag: b7535766-6ea4-4a0e-9ced-cecdf0ea6f03

	measure 'Ecart Facture-Encaisse' =
			
			[Montant Facture] - [Montant Encaisse]
		formatString: 0
		displayFolder: Trésorerie & Encaissements
		lineageTag: fc79c7ab-0d43-421c-8e4f-cd5aa9ec32a6

	measure 'Delai Moyen Paiement' =
			
			AVERAGEX(
			  FILTER(
			    Factures,
			    Factures[date_paiement] <> BLANK()
			  ),
			  Factures[date_paiement] - Factures[date_echeance]
			)
		displayFolder: Trésorerie & Encaissements
		lineageTag: 999ce824-82c5-4b88-b82b-54d4f7a2e214

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Montant En Retard' =
			
			CALCULATE(
			  SUM( Factures[montant_retard_23032026] ),
			  REMOVEFILTERS()
			)
		formatString: 0
		displayFolder: Relances & Retards
		lineageTag: f26d2f95-11c9-4883-b299-073d8319c7e0

	measure 'Nb Factures En Retard' =
			
			CALCULATE(
			  COUNTROWS( Factures ),
			  Factures[est_retard_23032026] = 1,
			  REMOVEFILTERS()
			)
		formatString: 0
		displayFolder: Relances & Retards
		lineageTag: ca2bfd18-7fdf-4148-b876-6cb04025e9f8

	measure 'Jours de Retard' =
			
			DATEDIFF(
			  MAX( Factures[date_echeance] ),
			  TODAY(),
			  DAY
			)
		formatString: 0
		displayFolder: Relances & Retards
		lineageTag: cfbeb973-a43a-4352-9468-191fb1f49336

	measure '% CA En Souffrance' =
			
			DIVIDE(
			  [Montant En Retard],
			  CALCULATE( [CA Facture HT], REMOVEFILTERS() )
			)
		displayFolder: Relances & Retards
		lineageTag: b567efc0-352d-48a6-9703-9098ec3cde97

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'FORMAT montant + nb factures en retards' = ```
			
			FORMAT([Montant En Retard], "# ##0 €") 
			& " · " & 
			FORMAT([Nb Factures En Retard], "0") & " fact."
			```
		displayFolder: Relances & Retards
		lineageTag: 3fd0a309-55c7-4734-8a10-1323cfad549d

	measure 'FORMAT montant + nb factures en retards (long)' = ```
			
			FORMAT([Nb Factures En Retard], "0") & " factures en retard" 
			& " · " & 
			FORMAT([Montant En Retard], "# ##0 €") & " non encaissés" 
			```
		displayFolder: Relances & Retards
		lineageTag: 13385072-e1bf-4e25-9f86-78bb03b7e3c3

	measure 'Valeur EBE Waterfall' =
			
			VAR etape = SELECTEDVALUE('Structure EBE'[Etape])
			VAR ebe = [CA facture ht] - [Couts Achats] - [Couts Charges Ext.] - [Couts Personnel]
			RETURN
			SWITCH(etape,
			    "CA",               [CA facture ht],
			    "Achats",           -[Couts Achats],
			    "Charges externes", -[Couts Charges Ext.],
			    "Personnel",        -[Couts Personnel],
			    "EBE",              BLANK()
			)
		formatString: 0
		displayFolder: EBE annuel
		lineageTag: 5fecfc79-225c-4538-a200-d69f87f443f1

	measure 'FORMAT Part EBE' =
			
			VAR _pct = ROUND([Taux EBE %] * 100, 1)
			RETURN
			IF(
			    ABS(_pct - ROUND(_pct, 0)) < 0.000001,
			    FORMAT(_pct, "0"),
			    FORMAT(_pct, "0.0")
			) & " % du CA"
		displayFolder: EBE annuel
		lineageTag: 2bcf6ec4-ed80-4d98-8072-1f8c9e9e0343

	measure 'Différence CA prévu et CA facturé' = [CA facture ht] - [CA Prevu HT]
