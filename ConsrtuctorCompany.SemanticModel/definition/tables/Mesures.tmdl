	measure 'Valeur EBE Waterfall' =
			
			VAR etape = SELECTEDVALUE('Structure EBE'[Etape])
			VAR ebe = [CA facture ht] - [Couts Achats] - [Couts Charges Ext.] - [Couts Personnel]
			RETURN
			SWITCH(etape,
			    "CA",               [CA facture ht],
			    "Achats",           -[Couts Achats],
			    "Charges externes", -[Couts Charges Ext.],
			    "Personnel",        -[Couts Personnel],
			    "EBE",              BLANK()
			)
		formatString: 0
		displayFolder: EBE annuel
		lineageTag: 5fecfc79-225c-4538-a200-d69f87f443f1

	measure 'FORMAT Part EBE' =
			
			VAR _pct = ROUND([Taux EBE %] * 100, 1)
			RETURN
			IF(
			    ABS(_pct - ROUND(_pct, 0)) < 0.000001,
			    FORMAT(_pct, "0"),
			    FORMAT(_pct, "0.0")
			) & " % du CA"
		displayFolder: EBE annuel
		lineageTag: 2bcf6ec4-ed80-4d98-8072-1f8c9e9e0343

