	measure 'Total Couts HT' =
			
			SUM(Couts[montant_ht])
		formatString: 0
		displayFolder: Couts opérationnels
		lineageTag: 350cf170-ff7f-4b9d-94e7-3d8ffee19cc3

	measure 'CA Prevu HT' = SUM( Chantiers[ca_prevu_ht] )
		formatString: 0
		displayFolder: Chiffre d'affaire
		lineageTag: f40e6bfc-88e0-4973-aca9-48f80b9ca9a1

	measure 'Ecart CA vs Prevu' = [CA facture ht] - [CA Prevu HT]
		formatString: 0
		displayFolder: Chiffre d'affaire
		lineageTag: 57e8160f-caec-4ef7-832d-f132c9485bb3

	measure 'Ecart CA % Prevu' = DIVIDE( [Ecart CA vs Prevu], [CA Prevu HT] )
		displayFolder: Chiffre d'affaire
		lineageTag: 743d5fa1-fbe3-4965-90e8-c54311658936

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Nb Chantiers' = COUNTROWS( Chantiers )
